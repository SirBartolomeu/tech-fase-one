{
  "Database": {
    "Provider": "Sqlite",
    "UseMigrations": false
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=oficina.db"
  },
  "Jwt": {
    "Issuer": "OficinaMvp",
    "Audience": "OficinaMvpClients",
    "Key": "OficinaMvp-ChaveJWT-SuperSecreta-Com-32-Caracteres",
    "ExpirationMinutes": 120
  },
  "AdminCredentials": {
    "Username": "admin",
    "Password": "Admin@123"
  },
  "Integration": {
    "Token": "oficina-integration-token-local-123456"
  },
  "Notifications": {
    "Mode": "Log",
    "From": "oficina@localhost",
    "ToOverride": "cliente.demo@oficina.local",
    "Smtp": {
      "Host": "localhost",
      "Port": 1025,
      "EnableSsl": false
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
